{
  "name": "sentinel-audit-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": ".\\venv\\Scripts\\python.exe -m backend.main",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.sentinel.audit",
    "productName": "Sentinel Audit",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "zip"
    },
    "forceCodeSigning": false,
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist_backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.292.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^4.4.5",
    "wait-on": "^9.0.4"
  }
}
